    "framer-motion": "^12.38.0",
    "lucide-react": "^1.6.0",
    "next": "16.2.1",
    "next-sitemap": "^4.2.3",
    "payload": "^3.80.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.72.0",
    "react-icons": "^5.6.0",
